# Tessera Invoice Inbox — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit real keys.

# --- Required ---------------------------------------------------------------
# Anthropic API key. This repo talks to the native Anthropic API (@anthropic-ai/sdk).
# Get one at https://console.anthropic.com/ . Without it, /api/extract returns a
# friendly 503 and the app never crashes.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: Cloudflare Turnstile (abuse guard, env-gated) ----------------
# If unset, Turnstile verification is skipped entirely. Set both to enable the
# invisible/managed challenge on the public demo (see lib/guards.ts).
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
